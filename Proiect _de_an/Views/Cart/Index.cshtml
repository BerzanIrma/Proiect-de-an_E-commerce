@model Proiect__de_an.Models.CartViewModel
@{
    ViewData["Title"] = "Coș";
}

<section class="py-5">
  <div class="container">
    <h1 class="mb-4">Coșul tău</h1>
    @if (Model.Items.Count == 0)
    {
      <p class="text-secondary">Nu ai produse în coș.</p>
      <a asp-controller="Shop" asp-action="Index" class="btn btn-primary">Vezi magazinul</a>
    }
    else
    {
      <div class="row">
        <div class="col-lg-8">
          <ul class="list-group list-group-flush">
            @for (var i = 0; i < Model.Items.Count; i++)
            {
              var item = Model.Items[i];
              <li class="list-group-item d-flex justify-content-between align-items-center">
                <div>
                  <strong>@item.Name</strong>
                  <span class="text-muted"> × @item.Quantity</span>
                </div>
                <div class="d-flex align-items-center gap-3">
                  <span>@item.LineTotal.ToString("C")</span>
                  <form method="post" asp-controller="Cart" asp-action="Remove" asp-route-index="@i">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm btn-outline-danger" aria-label="Șterge din coș">Șterge</button>
                  </form>
                </div>
              </li>
            }
          </ul>
        </div>
        <div class="col-lg-4 mt-4 mt-lg-0">
          <div class="card shadow-sm">
            <div class="card-body">
              <h5 class="card-title">Sumar</h5>
              <p class="d-flex justify-content-between mb-1"><span>Subtotal</span> <span>@Model.Subtotal.ToString("C")</span></p>
              <p class="d-flex justify-content-between mb-1">
                <span>Livrare (@(Model.DeliveryType == "Express" ? "Express" : "Standard"))</span>
                <span>@Model.DeliveryCost.ToString("C")</span>
              </p>
              <hr />
              <p class="d-flex justify-content-between fw-bold mb-0"><span>Total</span> <span>@Model.Total.ToString("C")</span></p>
              <form method="post" asp-controller="Cart" asp-action="SetDelivery" class="mt-3">
                @Html.AntiForgeryToken()
                <label class="form-label small">Tip livrare</label>
                <div class="form-check">
                  <input class="form-check-input" type="radio" name="deliveryType" id="page-delivery-standard" value="Standard" @(Model.DeliveryType == "Standard" ? "checked" : "") onchange="this.form.submit()">
                  <label class="form-check-label" for="page-delivery-standard">Standard (3–5 zile) — 5,00 lei</label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="radio" name="deliveryType" id="page-delivery-express" value="Express" @(Model.DeliveryType == "Express" ? "checked" : "") onchange="this.form.submit()">
                  <label class="form-check-label" for="page-delivery-express">Express (1–2 zile) — 15,00 lei</label>
                </div>
              </form>
              <a asp-action="Checkout" class="btn btn-primary w-100 mt-3 btn-lg">Finalizare comandă</a>
            </div>
          </div>
        </div>
      </div>
    }
  </div>
</section>
